{
  "name": "dame",
  "version": "4.8.1",
  "description": "Dossier Administratif des Membres Échiquéens",
  "scripts": {
    "build:css": "sass src/scss/:assets/css/ --style=compressed --no-source-map",
    "build:js": "node minify-js.js",
    "build": "npm run build:css && npm run build:js",
    "lint:js": "wp-scripts lint-js src/js/",
    "package": "node script/package.cjs",
    "watch": "sass --watch src/scss/:assets/css/"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@wordpress/scripts": "^32.6.0",
    "adm-zip": "^0.5.18",
    "minimatch": "^10.2.5",
    "sass": "^1.101.0",
    "terser": "^5.49.0"
  },
  "dependencies": {
    "pinia": "^3.0.4"
  }
}