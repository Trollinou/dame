{
  "name": "dame",
  "version": "4.8.2",
  "description": "Dossier Administratif des Membres Échiquéens",
  "scripts": {
    "build:css": "sass src/scss/:assets/css/ --style=compressed --no-source-map",
    "build:js": "node minify-js.js",
    "build": "npm run build:css && npm run build:js",
    "lint:js": "wp-scripts lint-js src/js/",
    "package": "node script/package.cjs",
    "watch": "sass --watch src/scss/:assets/css/"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@wordpress/scripts": "^33.0.0",
    "adm-zip": "^0.6.0",
    "minimatch": "^10.2.5",
    "sass": "^1.101.3",
    "terser": "^5.49.0"
  },
  "dependencies": {
    "pinia": "^4.0.2"
  },
  "allowScripts": {
    "@parcel/watcher@2.5.6": true,
    "core-js@3.49.0": true,
    "core-js-pure@3.49.0": true,
    "fsevents@2.3.3": true,
    "fsevents@2.3.2": true,
    "unrs-resolver@1.12.2": true
  }
}
