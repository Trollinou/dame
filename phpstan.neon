includes:
    - vendor/szepeviktor/phpstan-wordpress/extension.neon
parameters:
    level: 6
    phpVersion: 80400 # Force l'analyse pour PHP 8.4
    treatPhpDocTypesAsCertain: false
    bootstrapFiles:
        - dame.php
    paths:
        - dame.php
        - includes/
    excludePaths:
        - includes/lib/
